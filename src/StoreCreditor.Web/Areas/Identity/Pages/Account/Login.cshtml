@page
@model StoreCreditor.Web.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<h1 class="h3 mb-3">Sign in</h1>
<form method="post" asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="auth-form">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="ReturnUrl" />
    <div class="mb-3">
        <label asp-for="Input.Email" class="form-label"></label>
        <input asp-for="Input.Email" class="form-control" autocomplete="username" />
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.Password" class="form-label"></label>
        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" />
        <span asp-validation-for="Input.Password" class="text-danger"></span>
    </div>
    <div class="form-check mb-3">
        <input asp-for="Input.RememberMe" class="form-check-input" />
        <label asp-for="Input.RememberMe" class="form-check-label"></label>
    </div>
    <button class="btn btn-primary" type="submit">Sign in</button>
    <a asp-page="./ForgotPassword" class="btn btn-link">Forgot password</a>
</form>

@if (Model.ExternalLogins.Count > 0)
{
    <div class="auth-form mt-4">
        <hr />
        <form method="post" asp-page="./Login" asp-page-handler="ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl">
            @foreach (var provider in Model.ExternalLogins)
            {
                <button type="submit" class="btn btn-outline-primary" name="provider" value="@provider.Name">
                    Sign in with @provider.DisplayName
                </button>
            }
        </form>
    </div>
}
