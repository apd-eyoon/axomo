@model IReadOnlyList<AuditLog>
@{
    ViewData["Title"] = "Audit Logs";
}

<h1 class="h3 mb-3">Audit Logs</h1>
<div class="table-responsive">
    <table class="table table-sm align-middle">
        <thead>
            <tr>
                <th>Timestamp</th>
                <th>Level</th>
                <th>Category</th>
                <th>Action</th>
                <th>Message</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var log in Model)
        {
            <tr>
                <td>@log.Timestamp.LocalDateTime</td>
                <td>@log.Level</td>
                <td>@log.Category</td>
                <td>@log.Action</td>
                <td>@log.Message</td>
            </tr>
        }
        </tbody>
    </table>
</div>
