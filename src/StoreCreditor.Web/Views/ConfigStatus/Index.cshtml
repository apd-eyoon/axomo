@model IReadOnlyDictionary<string, bool>
@{
    ViewData["Title"] = "Configuration Status";
}

<h1 class="h3 mb-3">Configuration Status</h1>
<div class="list-group">
@foreach (var item in Model)
{
    <div class="list-group-item d-flex justify-content-between align-items-center">
        <span>@item.Key</span>
        <span class="badge @(item.Value ? "text-bg-success" : "text-bg-danger")">@(item.Value ? "Configured" : "Missing")</span>
    </div>
}
</div>
