@{
    ViewData["Title"] = "Job Status";
}

<h1 class="h3 mb-3">Job Status</h1>
@if (TempData["Message"] is string message)
{
    <div class="alert alert-success">@message</div>
}

<div class="d-flex flex-wrap gap-2 mb-4">
    <form asp-action="RunEmployeeImport" method="post">
        <button class="btn btn-primary" type="submit">Run Employee Import</button>
    </form>
    <form asp-action="RunStoreCredit" method="post">
        <button class="btn btn-success" type="submit">Run Store Credit</button>
    </form>
    <a class="btn btn-outline-secondary" href="/hangfire">Open Hangfire Dashboard</a>
</div>
