@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Dashboard</h1>
        <p class="text-muted mb-0">New employee store-credit automation.</p>
    </div>
    <a class="btn btn-outline-secondary" href="/hangfire">Hangfire</a>
</div>

<component type="typeof(StoreCreditor.Web.Components.DashboardCards)" render-mode="ServerPrerendered"
           param-Pending="Model.PendingEmployees"
           param-Processed="Model.ProcessedEmployees"
           param-Issued="Model.SuccessfulCredits" />

<div class="row g-4">
    <div class="col-lg-6">
        <h2 class="h5">Recent Employees</h2>
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead><tr><th>Name</th><th>Email</th><th>Status</th></tr></thead>
                <tbody>
                @foreach (var employee in Model.RecentEmployees)
                {
                    <tr>
                        <td>@employee.FirstName @employee.LastName</td>
                        <td>@employee.Email</td>
                        <td><span class="badge @(employee.Processed ? "text-bg-success" : "text-bg-warning")">@(employee.Processed ? "Processed" : "Pending")</span></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-lg-6">
        <h2 class="h5">Feature Flags</h2>
        <ul class="list-group">
            <li class="list-group-item d-flex justify-content-between">Pause Jobs <strong>@Model.FeatureFlags.PauseJobs</strong></li>
            <li class="list-group-item d-flex justify-content-between">Employee Import <strong>@Model.FeatureFlags.EnableEmployeeImport</strong></li>
            <li class="list-group-item d-flex justify-content-between">Credit Issuing <strong>@Model.FeatureFlags.EnableCreditIssuing</strong></li>
            <li class="list-group-item d-flex justify-content-between">Baseline Existing Employees <strong>@Model.FeatureFlags.BaselineExistingEmployeesAsInactive</strong></li>
            <li class="list-group-item d-flex justify-content-between">Dry Run <strong>@Model.FeatureFlags.DryRunMode</strong></li>
            <li class="list-group-item d-flex justify-content-between">Staging Mode <strong>@Model.FeatureFlags.StagingMode</strong></li>
            <li class="list-group-item d-flex justify-content-between">Staging Emails <strong>@Model.FeatureFlags.StagingEmployeeEmails.Length</strong></li>
        </ul>
    </div>
</div>
