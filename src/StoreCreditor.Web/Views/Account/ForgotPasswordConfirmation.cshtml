@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostEnvironment
@{
    ViewData["Title"] = "Password reset sent";
    var isDevelopment = string.Equals(
        HostEnvironment.EnvironmentName,
        Microsoft.Extensions.Hosting.Environments.Development,
        StringComparison.OrdinalIgnoreCase);
}

<h1 class="h3 mb-3">Password reset sent</h1>
<p>If the account exists and is confirmed, a reset link has been sent.</p>
@if (isDevelopment && ViewBag.ResetLink is string link)
{
    <p class="small text-muted">Development reset link: <a href="@link">@link</a></p>
}
